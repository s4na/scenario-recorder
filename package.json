{
  "name": "scenario-recorder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "lint": "oxlint --deny-warnings",
    "test": "vitest run",
    "test:e2e": "node tests/extension-flow.mjs",
    "build": "tsc --noEmit && vite build",
    "validate:extension": "node scripts/validate-extension.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/chrome": "^0.0.287",
    "@types/node": "^25.9.3",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "oxlint": "^1.70.0",
    "puppeteer-core": "^25.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.9"
  }
}
